# ─────────────────────────────────────────────────────────────────
# Qwerty Mode env vars (copy into govinda's .env)
# All variables are prefixed QWERTY_ so they cannot collide with
# anything in the actual qwerty (Lunar) repo.
# ─────────────────────────────────────────────────────────────────

# OpenAI key is shared with govinda; no need to duplicate.
# OPENAI_API_KEY=sk-...

# ── Cloudflare ────────────────────────────────────────────────────
QWERTY_CF_ACCOUNT_ID=
QWERTY_CF_VECTORIZE_API_TOKEN=
QWERTY_CF_VECTORIZE_INDEX=qwerty-mode-index

# ── Cloudflare R2 (S3-compatible) ────────────────────────────────
QWERTY_CF_R2_ACCESS_KEY_ID=
QWERTY_CF_R2_SECRET_ACCESS_KEY=
QWERTY_CF_R2_BUCKET=
QWERTY_CF_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ── Convex (govinda's qwerty deployment, NOT the lunar one) ──────
QWERTY_CONVEX_URL=https://<your-deployment>.convex.cloud
QWERTY_CONVEX_DEPLOY_KEY=
QWERTY_CONVEX_HTTP_PATH=/qwerty

# ── Tunables (optional) ──────────────────────────────────────────
# QWERTY_EMBEDDING_MODEL=text-embedding-3-small
# QWERTY_EMBEDDING_DIMS=1536
# QWERTY_TOP_K=12
# QWERTY_CHUNK_SIZE=600
# QWERTY_CHUNK_OVERLAP=80
# QWERTY_SYNTH_MODEL=gpt-5.2
# QWERTY_SYNTH_EFFORT=medium

# ── Frontend (web/.env.local) ────────────────────────────────────
# Add this to web/.env.local so the qwerty page can connect to Convex:
# NEXT_PUBLIC_QWERTY_CONVEX_URL=https://<your-deployment>.convex.cloud
