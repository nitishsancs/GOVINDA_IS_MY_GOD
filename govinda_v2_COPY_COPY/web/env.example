# ── Better Auth ───────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-chars

# URL where the Next.js app is running (used by Better Auth server)
BETTER_AUTH_URL=http://localhost:3000

# Public URL for the auth client (must match BETTER_AUTH_URL)
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# ── MongoDB (for auth storage) ────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
AUTH_DB_NAME=govinda_auth

# ── Existing ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
