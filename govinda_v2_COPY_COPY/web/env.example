# ── Better Auth ───────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-chars

# URL where the Next.js app is publicly accessible
# For local dev:  http://localhost:3000
# For ngrok:      https://your-domain.ngrok-free.app
# (start_backend.ps1 sets this automatically when -NgrokDomain is passed)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── MongoDB (for auth storage) ────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
AUTH_DB_NAME=govinda_auth

# ── Seed (one-time account creation) ─────────────────────────
SEED_SECRET=govinda-seed-2024

# ── Backend URL (server-side proxy destination — NOT exposed to browser) ──────
# Only needed if your FastAPI backend runs somewhere other than localhost:8001
# BACKEND_URL=http://localhost:8001
